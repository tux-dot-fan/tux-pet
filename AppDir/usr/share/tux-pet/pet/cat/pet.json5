{
  name: "Cat",
  avatar: "avatar.svg",
  animations: [
    { id: "idle",          name: "待机",     type: "frames", frames: ["idle1.svg",  "idle2.svg"],  ticks_per_frame: 10, behavior: { type: "idle" } },
    { id: "blink",         name: "眨眼",     type: "frames", frames: ["blink1.svg", "blink2.svg"], ticks_per_frame: 4,  behavior: { type: "idle" } },
    { id: "play",          name: "玩耍",     type: "frames", frames: ["play1.svg",  "play2.svg"],  ticks_per_frame: 4,  behavior: { type: "idle" } },
    { id: "shake",         name: "抖动",     type: "frames", frames: ["idle1.svg",  "idle2.svg"],  ticks_per_frame: 3,  behavior: { type: "shake" } },
    { id: "walk_right",    name: "走 →",     type: "frames", frames: ["walk1.svg",  "walk2.svg"],  ticks_per_frame: 5,  behavior: { type: "walk_right", speed: 1.8 } },
    { id: "walk_left",     name: "走 ←",     type: "frames", frames: ["walk1.svg",  "walk2.svg"],  ticks_per_frame: 5,  behavior: { type: "walk_left",  speed: 1.8 } },
    { id: "run_right",     name: "跑 →",     type: "frames", frames: ["walk1.svg",  "walk2.svg"],  ticks_per_frame: 2,  behavior: { type: "run_right",  speed: 5.0 } },
    { id: "run_left",      name: "跑 ←",     type: "frames", frames: ["walk1.svg",  "walk2.svg"],  ticks_per_frame: 2,  behavior: { type: "run_left",   speed: 5.0 } },
    { id: "chase_right",   name: "追逐 →",   type: "frames", frames: ["chase1.svg", "chase2.svg"], ticks_per_frame: 2,  behavior: { type: "run_right",  speed: 4.0 } },
    { id: "chase_left",    name: "追逐 ←",   type: "frames", frames: ["chase1.svg", "chase2.svg"], ticks_per_frame: 2,  behavior: { type: "run_left",   speed: 4.0 } },
    { id: "climb_up",      name: "爬上 ↑",   type: "frames", frames: ["chase1.svg", "chase2.svg"], ticks_per_frame: 4,  behavior: { type: "climb_up",   speed: 2.0 } },
    { id: "climb_down",    name: "爬下 ↓",   type: "frames", frames: ["chase1.svg", "chase2.svg"], ticks_per_frame: 4,  behavior: { type: "climb_down", speed: 2.0 } },
    { id: "jump",          name: "跳跃",     type: "frames", frames: ["play1.svg",  "play2.svg"],  ticks_per_frame: 3,  behavior: { type: "jump" } },
    { id: "fall",          name: "下落",     type: "frames", frames: ["chase1.svg", "chase2.svg"], ticks_per_frame: 4,  behavior: { type: "fall" } },
    { id: "follow",        name: "跟随鼠标", type: "frames", frames: ["chase1.svg", "chase2.svg"], ticks_per_frame: 4,  behavior: { type: "follow_cursor" } },
  ],
  rules: [
    { trigger_type: { type: "idle", min_ticks: 300, max_ticks: 1500 },
      animation: "blink", weight: 4.0, duration_ticks: 80 },
    { trigger_type: { type: "idle", min_ticks: 600, max_ticks: 2500 },
      animation: "play", weight: 3.0, duration_ticks: 120 },
    { trigger_type: { type: "idle", min_ticks: 1000, max_ticks: 4000 },
      animation: "shake", weight: 2.0, duration_ticks: 100 },
    { trigger_type: { type: "state", state: "hunger", op: "gt", value: 70.0 },
      animation: "shake", weight: 5.0, duration_ticks: 150, cooldown_ticks: 2000 },
    { trigger_type: { type: "state", state: "energy", op: "lt", value: 25.0 },
      animation: "idle", weight: 6.0, duration_ticks: 300, cooldown_ticks: 1500 },
    { trigger_type: { type: "state", state: "mood", op: "gt", value: 80.0 },
      animation: "chase_right", weight: 3.0, duration_ticks: 300, cooldown_ticks: 3000 },
    { trigger_type: { type: "time", hour_start: 23, hour_end: 7 },
      animation: "idle", weight: 5.0, duration_ticks: 500 },
  ],
}

